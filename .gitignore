# =============================================================================
#  BOF — public repo hygiene
#
#  This is a PUBLIC repo (github.com/dcmjlt/bof-web). Only the deployable
#  static site + Cloudflare Pages Function is tracked. Everything strategic,
#  internal, or working stays local-only.
#
#  Tracked (intentionally): index.html, privacy.html, robots.txt, sitemap.xml,
#  assets/**, about/**, services/**, hire/**, functions/** (Cloudflare Pages
#  Functions), scripts/**, .github/**, README.md, .gitignore
# =============================================================================

# --- OS / editor noise ---
.DS_Store
*.swp

# --- Local tooling / agent state (not part of the published site) ---
.gstack/
.claude/
.agents/
skills-lock.json

# --- Internal strategy & working documents (NEVER publish) ---
CLAUDE.md
AGENTS.md
POSITIONING.md
DESIGN.md
product.md
TODOS.md
copywriting-guide*.md
SEO-suggestion-homepage.md
SEO-*.md
COPY-REVIEW.md
COPY-*.md
KEYWORD-RESEARCH.md
KEYWORD-*.md

# --- Internal source material (pitch / branding / sitemap / USP) ---
*.pdf

# --- Internal client feedback (never publish) ---
back-office-factory-feedback.txt

# --- Designer share material & logo sources (working assets) ---
mockup-share/

# --- Print / stand assets (generated working artefacts) ---
print/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
