# Cloudflare Pages response headers. https://developers.cloudflare.com/pages/configuration/headers/
#
# Long-cache the self-hosted Cabinet Grotesk fonts. The filenames are weight-stable
# (cabinet-grotesk-<weight>.woff2) and the bytes effectively never change, so we let
# returning visitors skip the revalidation round-trip. Cloudflare Pages otherwise
# serves these with `Cache-Control: max-age=0, must-revalidate`, which forced a
# conditional request on every load and made font-display:swap flash longer than
# needed (and previously caused font-display:optional to miss its block window and
# drop the hero to the Arial fallback on prod).
#
# If a font file's bytes ever change, rename it (cache-bust) rather than editing in
# place — `immutable` means cached clients keep the old bytes until the URL changes.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
